# ============================================================
# LOCAL DEVELOPMENT (Supabase local dev + Inbucket)
# Run `supabase start` to get these values
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# PRODUCTION (timedshot.ca)
# ============================================================
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key
# NEXT_PUBLIC_SITE_URL=https://timedshot.ca

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Resend – required for the email-confirmation flow in production.
# Not required when ALLOW_DISPOSABLE_EMAILS=true (see below).
RESEND_API_KEY=

# Testing: set to "true" to enable full end-to-end email confirmation testing
# with temporary/disposable addresses (e.g. Mailinator).
#
# When "true":
#   - Supabase sends a real confirmation email to the provided address via its
#     built-in SMTP (no Resend API key required).
#   - The confirmation URL is ALSO returned directly in the API response so the
#     on-screen test-mode banner shows a direct clickable link as a backup, in
#     case the email is slow or filtered.
#
# Must be unset or "false" in production.
ALLOW_DISPOSABLE_EMAILS=true
